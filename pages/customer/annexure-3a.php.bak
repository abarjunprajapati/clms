<?php
/**
 * Customer Registration & Deployment Form
 * This is the customer's OWN registration form
 */

require_once '../../include/auth.php';
checkAuth(['customer', 'super_admin']);
include '../../include/config.php';
include '../../include/layout.php';

$role = $_SESSION['role'];
$name = $_SESSION['customer_name'] ?? $_SESSION['name'] ?? 'Customer';
$customer_code = $_SESSION['customer_code'] ?? '';
$user_id = $_SESSION['user_id'] ?? 0;

if (empty($customer_code)) {
    die('<div class="alert alert-danger m-5">Invalid Session. Please login as a customer.</div>');
}

// Handle form submission
$message = '';
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $action = $_POST['action'] ?? '';
    
    if ($action === 'save') {
        // Prepare data
        $customer_id = db_scalar($conn, "SELECT id FROM sap_customer_master WHERE customer_code = ?", 's', [$customer_code]);
        
        $total_strength = (int)($_POST['total_deployed_strength'] ?? 0);
        $skilled = (int)($_POST['skilled_workers'] ?? 0);
        $semi_skilled = (int)($_POST['semi_skilled_workers'] ?? 0);
        $unskilled = (int)($_POST['unskilled_workers'] ?? 0);
        $helpers = (int)($_POST['helpers'] ?? 0);
        
        $insurance_policy = $_POST['insurance_policy_no'] ?? '';
        $insurance_provider = $_POST['insurance_provider'] ?? '';
        $insurance_from = $_POST['insurance_valid_from'] ?? null;
        $insurance_to = $_POST['insurance_valid_to'] ?? null;
        $ecp_covered = $_POST['ecp_covered'] ?? 'NO';
        
        $epf_code = $_POST['epf_code'] ?? '';
        $epf_registered = $_POST['epf_registered'] ?? 'YES';
        $epf_reason = $_POST['epf_non_registration_reason'] ?? '';
        
        $esi_code = $_POST['esi_code'] ?? '';
        $esi_registered = $_POST['esi_registered'] ?? 'YES';
        $esi_reason = $_POST['esi_non_registration_reason'] ?? '';
        
        $klwf_registered = $_POST['klwf_registered'] ?? 'YES';
        $klwf_reason = $_POST['klwf_non_registration_reason'] ?? '';
        
        $training_cert = $_POST['safety_training_certificate'] ?? '';
        $training_expiry = $_POST['training_expiry_date'] ?? null;
        $gate_pass = $_POST['gate_pass_approved'] ?? 'NO';
        
        // Check if record exists
        $existing = db_single($conn, "SELECT id FROM customer_annexure3a WHERE customer_code = ?", 's', [$customer_code]);
        
        if ($existing) {
            // Update
            $sql = "UPDATE customer_annexure3a SET 
                total_deployed_strength = ?,
                skilled_workers = ?,
                semi_skilled_workers = ?,
                unskilled_workers = ?,
                helpers = ?,
                insurance_policy_no = ?,
                insurance_provider = ?,
                insurance_valid_from = ?,
                insurance_valid_to = ?,
                ecp_covered = ?,
                epf_code = ?,
                epf_registered = ?,
                epf_non_registration_reason = ?,
                esi_code = ?,
                esi_registered = ?,
                esi_non_registration_reason = ?,
                klwf_registered = ?,
                klwf_non_registration_reason = ?,
                safety_training_certificate = ?,
                training_expiry_date = ?,
                gate_pass_approved = ?,
                updated_by = ?,
                status = 'draft'
                WHERE customer_code = ?";
            
            db_execute($conn, $sql, 'iiiiisssssssssssssssi', [
                $total_strength, $skilled, $semi_skilled, $unskilled, $helpers,
                $insurance_policy, $insurance_provider, $insurance_from, $insurance_to,
                $ecp_covered,
                $epf_code, $epf_registered, $epf_reason,
                $esi_code, $esi_registered, $esi_reason,
                $klwf_registered, $klwf_reason,
                $training_cert, $training_expiry, $gate_pass,
                $user_id,
                $customer_code
            ]);
            $message = '<div class="alert alert-success"><i class="fas fa-check-circle"></i> Registration updated successfully!</div>';
        } else {
            // Insert
            $sql = "INSERT INTO customer_annexure3a (
                customer_id, customer_code, customer_name,
                total_deployed_strength, skilled_workers, semi_skilled_workers, unskilled_workers, helpers,
                insurance_policy_no, insurance_provider, insurance_valid_from, insurance_valid_to, ecp_covered,
                epf_code, epf_registered, epf_non_registration_reason,
                esi_code, esi_registered, esi_non_registration_reason,
                klwf_registered, klwf_non_registration_reason,
                safety_training_certificate, training_expiry_date, gate_pass_approved,
                status, created_by, created_at
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW())";
            
            db_execute($conn, $sql, 'issiiiiiissssssssssssss', [
                $customer_id, $customer_code, $name,
                $total_strength, $skilled, $semi_skilled, $unskilled, $helpers,
                $insurance_policy, $insurance_provider, $insurance_from, $insurance_to, $ecp_covered,
                $epf_code, $epf_registered, $epf_reason,
                $esi_code, $esi_registered, $esi_reason,
                $klwf_registered, $klwf_reason,
                $training_cert, $training_expiry, $gate_pass,
                'draft', $user_id
            ]);
            $message = '<div class="alert alert-success"><i class="fas fa-check-circle"></i> Registration created successfully!</div>';
        }
    } elseif ($action === 'submit') {
        // Submit for approval
        db_execute($conn, "UPDATE customer_annexure3a SET status = ?, submitted_at = NOW(), updated_by = ? WHERE customer_code = ?", 'sis', ['under_review', $user_id, $customer_code]);
        $message = '<div class="alert alert-success"><i class="fas fa-check-circle"></i> Registration submitted for review!</div>';
    }
}

// Fetch existing data
$existing = db_single($conn, "SELECT * FROM customer_annexure3a WHERE customer_code = ?", 's', [$customer_code]);
$customer_info = db_single($conn, "SELECT * FROM sap_customer_master WHERE customer_code = ?", 's', [$customer_code]);

