		<script>
			async function updateAnnexure3AStatus(id, status) {
				let remarks = '';
				if (status !== 'approved') {
					remarks = prompt('Enter remarks for this action:') || '';
					if (!remarks.trim()) return;
				}

				const formData = new FormData();
				formData.append('id', id);
				formData.append('status', status);
				formData.append('remarks', remarks);

				try {
					const response = await fetch('../../api/customer/update_3a_status.php', {
						method: 'POST',
						body: formData
					});
					const result = await response.json();
					if (result.success) {
						if (typeof window.notifyUser === 'function') {
							await window.notifyUser('Customer Registration status updated.', 'success', 'Updated');
						}
						window.location.reload();
					} else {
						const message = result.message || 'Status update failed.';
						if (typeof window.notifyUser === 'function') {
							window.notifyUser(message, 'error', 'Failed');
						} else {
							alert(message);
						}
					}
				} catch (error) {
					alert(error.message || 'Unable to update status.');
				}
			}

			document.addEventListener('DOMContentLoaded', function () {
				const attendanceData = <?= json_encode($attendanceTrend) ?>;
				const statusData = <?= json_encode($statusStats) ?>;
				const palette = ['#f59e0b', '#22c55e', '#ef4444', '#0ea5e9'];
				const chartText = '#475569';

				new Chart(document.getElementById('attendanceChart'), {
					type: 'bar',
					data: {
						labels: attendanceData.map(item => item.date),
						datasets: [{ data: attendanceData.map(item => Number(item.count || 0)), backgroundColor: '#0ea5e9', borderRadius: 6 }]
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: { legend: { display: false } },
						scales: {
							y: { beginAtZero: true, grid: { color: 'rgba(148,163,184,.22)' }, ticks: { color: chartText } },
							x: { grid: { display: false }, ticks: { color: chartText } }
						}
					}
				});

				new Chart(document.getElementById('statusChart'), {
					type: 'doughnut',
					data: {
						labels: statusData.map(item => item.label),
						datasets: [{ data: statusData.map(item => Number(item.value || 0)), backgroundColor: palette, borderWidth: 0 }]
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: { legend: { position: 'bottom', labels: { color: chartText, boxWidth: 12, font: { size: 11 } } } }
					}
				});
			});
		</script>
