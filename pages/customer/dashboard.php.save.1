function customerDashboardCount($conn, $sql, $types = '', $params = array()) {
	try {
		return db_count($conn, $sql, $types, $params);
	} catch (Exception $e) {
		return 0;
	}
}

function customerDashboardRows(mysqli $conn, string $sql, string $types = '', array $params = []): array {
		try {
				return db_fetch_all($conn, $sql, $types, $params);
		} catch (Throwable $e) {
				return [];
		}
}

function customerDashboardSingle(mysqli $conn, string $sql, string $types = '', array $params = []): ?array {
		try {
				return db_single($conn, $sql, $types, $params);
		} catch (Throwable $e) {
				return null;
		}
}

function customerBadgeClass(string $status): string {
		$status = strtolower($status);
		if (in_array($status, ['approved', 'verified', 'active', 'pass', 'passed', 'completed'], true)) return 'success';
		if (in_array($status, ['rejected', 'expired', 'blocked', 'failed', 'fail'], true)) return 'danger';
		if (in_array($status, ['correction_required', 'resubmit_required', 'reupload_required'], true)) return 'warning';
		return 'info';
}

function renderContent() {
		global $conn, $customer_code, $customer_name;

		$contractorJoin = "
				FROM work_orders wo
				LEFT JOIN contractors c ON c.vendor_code = wo.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE'
		";
		$workerJoin = "
				FROM workmen w
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE'
		";

		$totalContractors = customerDashboardCount($conn, "SELECT COUNT(DISTINCT wo.vendor_code) c {$contractorJoin}", 's', [$customer_code]);
		$totalWorkers = customerDashboardCount($conn, "SELECT COUNT(*) c {$workerJoin}", 's', [$customer_code]);
		$pendingAnnexure3a = customerDashboardCount($conn, "
				SELECT COUNT(*) c
				FROM work_orders wo
				LEFT JOIN contractor_annexure3a a ON a.customer_code = wo.customer_code AND a.work_order_no = wo.work_order_no
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE'
					AND COALESCE(a.status, 'pending') IN ('pending','submitted','under_review','correction_required','resubmit_required')
		", 's', [$customer_code]);
		$pendingAnnexure4a = customerDashboardCount($conn, "SELECT COUNT(*) c {$workerJoin} AND COALESCE(w.welfare_user_verified,0)=0", 's', [$customer_code]);
		$pendingGatePass = customerDashboardCount($conn, "
				SELECT COUNT(*) c
				FROM gate_passes gp
				JOIN workmen w ON w.id = gp.workman_id
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE' AND gp.status='pending'
		", 's', [$customer_code]);
		$safetyPending = customerDashboardCount($conn, "SELECT COUNT(*) c {$workerJoin} AND COALESCE(w.training_status,'pending') IN ('pending','training_pending','training_scheduled','fail','failed','training_failed')", 's', [$customer_code]);
		$compliancePending = customerDashboardCount($conn, "
				SELECT COUNT(*) c
				FROM compliance comp
				JOIN contractors c ON c.id = comp.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE' AND COALESCE(comp.status,'pending') IN ('pending','reupload_required','rejected')
		", 's', [$customer_code]);
		$expiredDocuments = customerDashboardCount($conn, "
				SELECT COUNT(*) c
				FROM contractor_annexure3a a
				WHERE a.customer_code = ?
					AND (
						(a.insurance_validity IS NOT NULL AND a.insurance_validity < CURDATE())
						OR (a.labour_license_expiry_date IS NOT NULL AND a.labour_license_expiry_date < CURDATE())
					)
		", 's', [$customer_code]);
		$liveAttendance = customerDashboardCount($conn, "
				SELECT COUNT(DISTINCT a.workman_id) c
				FROM attendance a
				JOIN workmen w ON w.id = a.workman_id
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE' AND DATE(a.check_in)=CURDATE()
		", 's', [$customer_code]);
		$workersInside = customerDashboardCount($conn, "
				SELECT COUNT(DISTINCT a.workman_id) c
				FROM attendance a
				JOIN workmen w ON w.id = a.workman_id
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE' AND DATE(a.check_in)=CURDATE() AND a.check_out IS NULL
		", 's', [$customer_code]);
		$approvedAnnexure3a = customerDashboardCount($conn, "SELECT COUNT(*) c FROM contractor_annexure3a WHERE customer_code = ? AND status='approved'", 's', [$customer_code]);
		$rejectedAnnexure3a = customerDashboardCount($conn, "SELECT COUNT(*) c FROM contractor_annexure3a WHERE customer_code = ? AND status='rejected'", 's', [$customer_code]);
		$blockedWorkers = customerDashboardCount($conn, "SELECT COUNT(*) c {$workerJoin} AND COALESCE(w.is_blocked,0)=1", 's', [$customer_code]);

		$recentAnnexure3a = customerDashboardRows($conn, "
				SELECT a.id, a.vendor_code, a.work_order_no, a.status, a.updated_at, a.created_at,
							 COALESCE(v.vendor_name, c.contractor_name, a.contractor_name, a.vendor_code) contractor_name,
							 COALESCE(a.esi_code, v.esi_no, c.esi_code) esi,
							 COALESCE(a.epf_code, v.pf_no, c.epf_code) pf,
							 COALESCE(a.labour_license_expiry_date, c.expiry_date) license_validity
				FROM contractor_annexure3a a
				LEFT JOIN sap_vendor_master v ON v.vendor_code = a.vendor_code
				LEFT JOIN contractors c ON c.vendor_code = a.vendor_code
				WHERE a.customer_code = ?
				ORDER BY a.id DESC
				LIMIT 8
		", 's', [$customer_code]);

		$pendingWorkers = customerDashboardRows($conn, "
				SELECT w.id, w.name worker_name, w.aadhaar, w.skill_category, w.training_status, w.status,
							 COALESCE(v.vendor_name, c.contractor_name, c.vendor_code) contractor_name
				FROM workmen w
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				LEFT JOIN sap_vendor_master v ON v.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE'
				ORDER BY w.id DESC
				LIMIT 6
		", 's', [$customer_code]);

		$attendanceTrend = customerDashboardRows($conn, "
				SELECT DATE(a.check_in) date, COUNT(DISTINCT a.workman_id) count
				FROM attendance a
				JOIN workmen w ON w.id = a.workman_id
				JOIN contractors c ON c.id = w.contractor_id
				JOIN work_orders wo ON wo.vendor_code = c.vendor_code
				WHERE wo.customer_code = ? AND wo.wo_status = 'ACTIVE' AND a.check_in >= DATE_SUB(CURDATE(), INTERVAL 6 DAY)
				GROUP BY DATE(a.check_in)
				ORDER BY date ASC
		", 's', [$customer_code]);

		$statusStats = [
