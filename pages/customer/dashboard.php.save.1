				['Safety Pending', $safetyPending, 'Training or re-test pending', 'fa-helmet-safety', '#ca8a04', '#fef9c3'],
				['Compliance Pending', $compliancePending, 'ESI/PF/KLUWF verification queue', 'fa-shield-halved', '#be123c', '#ffe4e6'],
				['Expired Documents', $expiredDocuments, 'Insurance/license date alerts', 'fa-file-circle-exclamation', '#dc2626', '#fee2e2'],
				['Live Attendance', $liveAttendance, 'Present today', 'fa-calendar-check', '#0ea5e9', '#cffafe'],
